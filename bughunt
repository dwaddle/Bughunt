#!/usr/bin/env python3
"""
Bughunt CLI: The central entry point for the Bughunt security suite.
"""

import sys
import os
import subprocess
import argparse

# Path configuration
PROJECT_ROOT = os.path.dirname(os.path.abspath(__file__))
TOOLS_DIR = os.path.join(PROJECT_ROOT, "tools")

def run_tool(tool_name, args):
    tool_path = os.path.join(TOOLS_DIR, tool_name)
    if not os.path.exists(tool_path):
        print(f"[!] Error: Tool '{tool_name}' not found at {tool_path}")
        return
    
    cmd = [sys.executable, tool_path] + args
    try:
        # Run the tool and pipe output to terminal
        subprocess.run(cmd, check=False)
    except KeyboardInterrupt:
        print("\n[!] Execution interrupted by user.")
    except Exception as e:
        print(f"[!] Critical Error running {tool_name}: {e}")

def main():
    parser = argparse.ArgumentParser(
        description="🎯 Bughunt Security Suite: Central CLI Interface",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Available Sub-commands:
  recon <target>    Start full automated reconnaissance (Master-Recon)
  domain <domain>   Explore infrastructure and subdomains (Domain-Explorer)
  scan <url>        Run a directory discovery scan (Directory-Scanner)
  brute <url>       Test for default credentials (Auth-Bruter)
  audit <url>       Audit for crypto and design flaws (Crypto-Audit / Design-Audit)
  lfi/sqli <url>    Run specific injection tests (LFI-Scanner / SQLi-Tester)
  ai <file>         Get an AI expert opinion on a file (AI-Analyzer)

Example:
  bughunt recon 10.10.10.10
  bughunt domain example.com --out-of-scope "test,dev"
        """
    )
    
    # We use parse_known_args to pass everything else to the sub-tools
    parser.add_argument("command", help="The sub-command to execute")
    parser.add_argument("target_args", nargs=argparse.REMAINDER, help="Arguments passed to the specific tool")

    if len(sys.argv) < 2:
        parser.print_help()
        sys.exit(1)

    args = parser.parse_args()
    cmd = args.command.lower()
    t_args = args.target_args

    # Mapping commands to tool filenames
    mapping = {
        "recon": "master_recon.py",
        "domain": "domain_explorer.py",
        "scan": "directory_scanner.py",
        "brute": "auth_bruter.py",
        "audit": "crypto_audit.py",
        "lfi": "lfi_scanner.py",
        "sqli": "sqli_tester.py",
        "cmd": "cmd_injection_tester.py",
        "ai": "ai_analyzer.py",
        "sca": "hunter_sca.py",
        "nuclei": "nuclei_scanner.py"
    }

    if cmd in mapping:
        run_tool(mapping[cmd], t_args)
    else:
        # Fallback: if user types 'bughunt 10.10.10.10', assume 'recon'
        if "." in cmd or ":" in cmd:
            print(f"[*] No command specified. Defaulting to 'recon' for {cmd}...")
            run_tool("master_recon.py", [cmd] + t_args)
        else:
            print(f"[!] Unknown command: {cmd}")
            parser.print_help()

if __name__ == "__main__":
    main()
